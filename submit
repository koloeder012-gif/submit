// ==UserScript==
// @name         Auto-Submit mas bloqueo de captchas
// @namespace    http://violentmonkey.net/
// @version      3.5.0
// @description  Auto-submit - SIN notificación de precio bajo
// @author       TuNombre
// @match        https://kolotibablo.com/*
// @grant        GM_getValue
// @grant        GM_setValue
// @updateURL    https://raw.githubusercontent.com/TU_USUARIO/TU_REPO/main/kolotibablo-auto.user.js
// @downloadURL  https://raw.githubusercontent.com/TU_USUARIO/TU_REPO/main/kolotibablo-auto.user.js
// @homepageURL  https://github.com/TU_USUARIO/TU_REPO
// @supportURL   https://github.com/TU_USUARIO/TU_REPO/issues
// ==/UserScript==

(function () {
    'use strict';

    const respuestasMalas = ['empty', 'v', 'y', '0', 'b', 'j', 'm', '-4', '-5', 'D', 'W', 'v54', '9', '-1', '-2', '348', '4', '7', '929','2','v54', '6', '3', '5'];

    let config = { funcionActiva: true, tiempoEspera: 1 };
    let timeoutId = null;
    let textoAnterior = '';

    function esTextoBloqueado(texto) {
        if (!texto) return false;
        return respuestasMalas.some(p => texto.trim().toLowerCase() === p.toLowerCase());
    }

    function hacerClickSubmit() {
        if (window.__CAPTCHA_BLOQUEADO__ === true) return;
        const btn = document.querySelector('.submit-wrap button.btn.btn-default');
        if (btn && !btn.disabled) btn.click();
    }

    function manejarDeteccionTexto() {
        if (!config.funcionActiva) return;
        if (window.KOLO_SYNC?.correctorOcupado) return;

        const input = document.querySelector('input.inp-dft.w100p');
        if (!input) return;

        const textoActual = input.value.trim();

        if (esTextoBloqueado(textoActual)) {
            window.__CAPTCHA_BLOQUEADO__ = true;
            clearTimeout(timeoutId);
            textoAnterior = textoActual;
            return;
        }

        window.__CAPTCHA_BLOQUEADO__ = false;

        if (textoActual && textoActual !== textoAnterior) {
            textoAnterior = textoActual;
            clearTimeout(timeoutId);
            timeoutId = setTimeout(() => {
                if (!window.KOLO_SYNC?.correctorOcupado) {
                    hacerClickSubmit();
                    setTimeout(() => textoAnterior = '', 500);
                }
            }, config.tiempoEspera * 1000);
        }
    }

    function init() {
        console.log('✅ Script Auto-Submit iniciado correctamente');
        
        const input = document.querySelector('input.inp-dft.w100p');
        if (input) {
            input.addEventListener('input', manejarDeteccionTexto);
            input.addEventListener('change', manejarDeteccionTexto);
        }

        new MutationObserver(() => {
            const newInput = document.querySelector('input.inp-dft.w100p');
            if (newInput && !newInput.__submitHooked) {
                newInput.__submitHooked = true;
                newInput.addEventListener('input', manejarDeteccionTexto);
                newInput.addEventListener('change', manejarDeteccionTexto);
            }
        }).observe(document.body, { childList: true, subtree: true });
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
})();
